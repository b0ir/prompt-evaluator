# ── Model selection ────────────────────────────────────────────────────────────
# LiteLLM model string: <provider>/<model-name>
# Default (no change needed if you use OpenRouter):
LLM_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free

# Other examples:
# LLM_MODEL=anthropic/claude-sonnet-4-5
# LLM_MODEL=openai/gpt-4o
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_MODEL=groq/llama-3.3-70b-versatile
# LLM_MODEL=nvidia_nim/meta/llama-3.1-8b-instruct
# LLM_MODEL=ollama/llama3          # local — no API key needed

# ── API keys ───────────────────────────────────────────────────────────────────
# Set the key for whichever provider your LLM_MODEL uses.
# LiteLLM picks these up automatically by convention.

OPENROUTER_API_KEY=sk-or-your-key-here   # openrouter/*
# ANTHROPIC_API_KEY=sk-ant-...           # anthropic/*
# OPENAI_API_KEY=sk-...                  # openai/*
# GEMINI_API_KEY=...                     # gemini/*
# GROQ_API_KEY=gsk_...                   # groq/*
# XAI_API_KEY=...                        # xai/*
# DEEPSEEK_API_KEY=...                   # deepseek/*
# TOGETHERAI_API_KEY=...                 # together_ai/*
# MISTRAL_API_KEY=...                    # mistral/*
# NVIDIA_NIM_API_KEY=nvapi-...           # nvidia_nim/*

# Alternatively, use a single generic key (takes precedence over provider-specific ones):
# LLM_API_KEY=your-key-here

# ── Custom endpoint (optional) ─────────────────────────────────────────────────
# Override the base URL — useful for Ollama, vLLM, or any OpenAI-compatible server.
# LLM_BASE_URL=http://localhost:11434
